{
  "name": "devcontract-vscode",
  "displayName": "DevContract",
  "description": "Repository setup, shared local secrets, and health checks for development teams",
  "version": "1.0.0",
  "publisher": "devcontract",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "onboarding",
    "secrets",
    "bootstrap",
    "environment",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dantwoashim/DevContract"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.devcontract/contract.yaml",
    "workspaceContains:WORKSPACE.md"
  ],
  "files": [
    "out/**/*",
    "src/**/*",
    "package.json",
    "tsconfig.json",
    "LICENSE.txt"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devcontract.bootstrap",
        "title": "DevContract: Bootstrap"
      },
      {
        "command": "devcontract.doctor",
        "title": "DevContract: Doctor"
      },
      {
        "command": "devcontract.agentInstall",
        "title": "DevContract: Install Tool Files"
      },
      {
        "command": "devcontract.guardScan",
        "title": "DevContract: Guard Scan"
      },
      {
        "command": "devcontract.run",
        "title": "DevContract: Run Default Target"
      },
      {
        "command": "devcontract.status",
        "title": "DevContract: Status"
      },
      {
        "command": "devcontract.installHelp",
        "title": "DevContract: Install CLI Help"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devcontract",
          "title": "DevContract",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "devcontract": [
        {
          "id": "devcontract.actions",
          "name": "Workflow"
        },
        {
          "id": "devcontract.health",
          "name": "Health"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node ./node_modules/typescript/bin/tsc -p ./",
    "watch": "node ./node_modules/typescript/bin/tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
